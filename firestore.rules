rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      
      allow create: if isOwner(userId)
        && isValidId(userId)
        && incoming().uid == request.auth.uid
        && incoming().nickname is string
        && incoming().nickname.size() >= 2
        && incoming().nickname.size() <= 20
        && incoming().role in ['Admin', 'Moderator', 'Member']
        && incoming().joinedAt == request.time
        && incoming().status in ['online', 'offline', 'away'];

      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().joinedAt == existing().joinedAt
        && incoming().nickname is string
        && incoming().nickname.size() >= 2
        && incoming().nickname.size() <= 20
        && incoming().status in ['online', 'offline', 'away']
        // Prevent users from escalating their own role unless they keep their original role
        && incoming().role == existing().role;
    }

    // Nicknames unique checks
    match /nicknames/{nickname} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && incoming().uid == request.auth.uid
        && incoming().nickname == nickname;
      allow delete: if isSignedIn()
        && existing().uid == request.auth.uid;
    }

    // Rooms Collection
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn()
        && isValidId(roomId)
        && incoming().id == roomId
        && incoming().ownerId == request.auth.uid
        && incoming().name is string
        && incoming().name.size() >= 2
        && incoming().name.size() <= 50
        && incoming().createdAt == request.time
        && incoming().isProtected is boolean;

      allow update: if isSignedIn()
        && (
          // Option A: Room Owner updates metadata
          (existing().ownerId == request.auth.uid 
            && incoming().id == existing().id
            && incoming().ownerId == existing().ownerId
            && incoming().createdAt == existing().createdAt
            && incoming().name is string
            && incoming().name.size() >= 2
            && incoming().name.size() <= 50
          )
          // Option B: Any user can increment/decrement current visitor counts
          || (incoming().diff(existing()).affectedKeys().hasOnly(['memberCount']))
        );

      allow delete: if isSignedIn()
        && existing().ownerId == request.auth.uid;
    }

    // Room Messages Collection
    match /rooms/{roomId}/messages/{messageId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn()
        && isValidId(messageId)
        && incoming().id == messageId
        && incoming().senderId == request.auth.uid
        && incoming().text is string
        && incoming().text.size() <= 2000
        && incoming().createdAt == request.time;

      allow delete: if isSignedIn()
       && (
         existing().senderId == request.auth.uid
         || get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid
       );
    }

    // Direct Conversation threads
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (request.auth.uid in existing().participants);
      
      allow create: if isSignedIn()
        && isValidId(conversationId)
        && (request.auth.uid in incoming().participants)
        && incoming().participants.size() == 2;

      allow update: if isSignedIn()
        && (request.auth.uid in existing().participants)
        && incoming().participants == existing().participants
        && (incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt']));
    }

    // Direct Messages Collection
    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
      
      allow create: if isSignedIn()
        && isValidId(messageId)
        && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants)
        && incoming().senderId == request.auth.uid
        && incoming().text is string
        && incoming().text.size() <= 2000
        && incoming().createdAt == request.time;
    }
  }
}
